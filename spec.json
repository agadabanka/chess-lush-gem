{
  "meta": {
    "name": "Chess",
    "version": "1.0.0",
    "description": "Classic chess game with piece movement and capture mechanics"
  },
  "config": {
    "display": {
      "type": "grid",
      "width": 8,
      "height": 8,
      "cellSize": 60,
      "background": "#f0d9b5"
    },
    "timing": {
      "tickRate": 1000
    },
    "input": {
      "select": {
        "keys": [
          " ",
          "Enter"
        ]
      },
      "up": {
        "keys": [
          "ArrowUp",
          "w"
        ]
      },
      "down": {
        "keys": [
          "ArrowDown",
          "s"
        ]
      },
      "left": {
        "keys": [
          "ArrowLeft",
          "a"
        ]
      },
      "right": {
        "keys": [
          "ArrowRight",
          "d"
        ]
      },
      "restart": {
        "keys": [
          "r",
          "R"
        ]
      }
    }
  },
  "componentTypes": {
    "Position": {
      "fields": {
        "x": {
          "type": "int",
          "default": 0
        },
        "y": {
          "type": "int",
          "default": 0
        }
      }
    },
    "ChessPiece": {
      "fields": {
        "type": {
          "type": "enum",
          "enum": [
            "pawn",
            "rook",
            "knight",
            "bishop",
            "queen",
            "king"
          ]
        },
        "color": {
          "type": "enum",
          "enum": [
            "white",
            "black"
          ]
        },
        "hasMoved": {
          "type": "bool",
          "default": false
        },
        "displayChar": {
          "type": "string"
        }
      }
    },
    "Selected": {
      "fields": {}
    },
    "Cursor": {
      "fields": {
        "color": {
          "type": "color",
          "default": "#ff0"
        }
      }
    },
    "Board": {
      "fields": {
        "grid": {
          "type": "grid",
          "dimensions": {
            "widthRef": "config.display.width",
            "heightRef": "config.display.height"
          }
        }
      }
    }
  },
  "archetypes": {
    "whitePawn": {
      "components": {
        "Position": {
          "x": 0,
          "y": 6
        },
        "ChessPiece": {
          "type": "pawn",
          "color": "white",
          "displayChar": "♙"
        }
      }
    },
    "blackPawn": {
      "components": {
        "Position": {
          "x": 0,
          "y": 1
        },
        "ChessPiece": {
          "type": "pawn",
          "color": "black",
          "displayChar": "♟"
        }
      }
    },
    "whiteRook": {
      "components": {
        "Position": {
          "x": 0,
          "y": 7
        },
        "ChessPiece": {
          "type": "rook",
          "color": "white",
          "displayChar": "♖"
        }
      }
    },
    "blackRook": {
      "components": {
        "Position": {
          "x": 0,
          "y": 0
        },
        "ChessPiece": {
          "type": "rook",
          "color": "black",
          "displayChar": "♜"
        }
      }
    },
    "whiteKnight": {
      "components": {
        "Position": {
          "x": 1,
          "y": 7
        },
        "ChessPiece": {
          "type": "knight",
          "color": "white",
          "displayChar": "♘"
        }
      }
    },
    "blackKnight": {
      "components": {
        "Position": {
          "x": 1,
          "y": 0
        },
        "ChessPiece": {
          "type": "knight",
          "color": "black",
          "displayChar": "♞"
        }
      }
    },
    "whiteBishop": {
      "components": {
        "Position": {
          "x": 2,
          "y": 7
        },
        "ChessPiece": {
          "type": "bishop",
          "color": "white",
          "displayChar": "♗"
        }
      }
    },
    "blackBishop": {
      "components": {
        "Position": {
          "x": 2,
          "y": 0
        },
        "ChessPiece": {
          "type": "bishop",
          "color": "black",
          "displayChar": "♝"
        }
      }
    },
    "whiteQueen": {
      "components": {
        "Position": {
          "x": 3,
          "y": 7
        },
        "ChessPiece": {
          "type": "queen",
          "color": "white",
          "displayChar": "♕"
        }
      }
    },
    "blackQueen": {
      "components": {
        "Position": {
          "x": 3,
          "y": 0
        },
        "ChessPiece": {
          "type": "queen",
          "color": "black",
          "displayChar": "♛"
        }
      }
    },
    "whiteKing": {
      "components": {
        "Position": {
          "x": 4,
          "y": 7
        },
        "ChessPiece": {
          "type": "king",
          "color": "white",
          "displayChar": "♔"
        }
      }
    },
    "blackKing": {
      "components": {
        "Position": {
          "x": 4,
          "y": 0
        },
        "ChessPiece": {
          "type": "king",
          "color": "black",
          "displayChar": "♚"
        }
      }
    },
    "cursor": {
      "singleton": true,
      "components": {
        "Position": {
          "x": 4,
          "y": 4
        },
        "Cursor": {
          "color": "#ff0"
        }
      }
    },
    "board": {
      "singleton": true,
      "components": {
        "Board": {}
      }
    }
  },
  "resources": {
    "state": {
      "score": 0,
      "level": 1,
      "gameOver": false,
      "currentTurn": "white",
      "whiteInCheck": false,
      "blackInCheck": false,
      "moveCount": 0
    }
  },
  "systems": [
    {
      "name": "spawn",
      "type": "custom",
      "config": {
        "code": "function spawnChessPieces(world) { const pieces = [{ archetype: 'whiteRook', x: 0, y: 7 }, { archetype: 'whiteKnight', x: 1, y: 7 }, { archetype: 'whiteBishop', x: 2, y: 7 }, { archetype: 'whiteQueen', x: 3, y: 7 }, { archetype: 'whiteKing', x: 4, y: 7 }, { archetype: 'whiteBishop', x: 5, y: 7 }, { archetype: 'whiteKnight', x: 6, y: 7 }, { archetype: 'whiteRook', x: 7, y: 7 }, { archetype: 'whitePawn', x: 0, y: 6 }, { archetype: 'whitePawn', x: 1, y: 6 }, { archetype: 'whitePawn', x: 2, y: 6 }, { archetype: 'whitePawn', x: 3, y: 6 }, { archetype: 'whitePawn', x: 4, y: 6 }, { archetype: 'whitePawn', x: 5, y: 6 }, { archetype: 'whitePawn', x: 6, y: 6 }, { archetype: 'whitePawn', x: 7, y: 6 }, { archetype: 'blackRook', x: 0, y: 0 }, { archetype: 'blackKnight', x: 1, y: 0 }, { archetype: 'blackBishop', x: 2, y: 0 }, { archetype: 'blackQueen', x: 3, y: 0 }, { archetype: 'blackKing', x: 4, y: 0 }, { archetype: 'blackBishop', x: 5, y: 0 }, { archetype: 'blackKnight', x: 6, y: 0 }, { archetype: 'blackRook', x: 7, y: 0 }, { archetype: 'blackPawn', x: 0, y: 1 }, { archetype: 'blackPawn', x: 1, y: 1 }, { archetype: 'blackPawn', x: 2, y: 1 }, { archetype: 'blackPawn', x: 3, y: 1 }, { archetype: 'blackPawn', x: 4, y: 1 }, { archetype: 'blackPawn', x: 5, y: 1 }, { archetype: 'blackPawn', x: 6, y: 1 }, { archetype: 'blackPawn', x: 7, y: 1 }, { archetype: 'cursor', x: 4, y: 4 }, { archetype: 'board', x: 0, y: 0 }]; pieces.forEach(piece => { const eid = world.createEntity(); if (piece.archetype === 'cursor') { world.addComponent(eid, 'Position', { x: piece.x, y: piece.y }); world.addComponent(eid, 'Cursor', { color: '#ff0' }); } else if (piece.archetype === 'board') { world.addComponent(eid, 'Board', {}); } else { world.addComponent(eid, 'Position', { x: piece.x, y: piece.y }); const pieceType = piece.archetype.replace('white', '').replace('black', '').toLowerCase(); const color = piece.archetype.includes('white') ? 'white' : 'black'; const chars = { white: { pawn: '♙', rook: '♖', knight: '♘', bishop: '♗', queen: '♕', king: '♔' }, black: { pawn: '♟', rook: '♜', knight: '♞', bishop: '♝', queen: '♛', king: '♚' } }; world.addComponent(eid, 'ChessPiece', { type: pieceType, color: color, hasMoved: false, displayChar: chars[color][pieceType] }); } }); }"
      }
    },
    {
      "name": "input",
      "type": "input",
      "config": {
        "target": "cursor",
        "actions": {
          "up": {
            "move": [
              0,
              -1
            ]
          },
          "down": {
            "move": [
              0,
              1
            ]
          },
          "left": {
            "move": [
              -1,
              0
            ]
          },
          "right": {
            "move": [
              1,
              0
            ]
          },
          "select": {
            "action": "selectOrMove"
          }
        }
      }
    },
    {
      "name": "wrap",
      "type": "wrap",
      "config": {
        "target": "cursor"
      }
    },
    {
      "name": "collision",
      "type": "collision",
      "config": {
        "chessRules": true,
        "turnBased": true
      }
    },
    {
      "name": "scoring",
      "type": "scoring",
      "config": {
        "resource": "state",
        "captureScores": {
          "pawn": 1,
          "knight": 3,
          "bishop": 3,
          "rook": 5,
          "queen": 9,
          "king": 1000
        }
      }
    },
    {
      "name": "gameOver",
      "type": "gameOver",
      "config": {
        "condition": "state.gameOver"
      }
    },
    {
      "name": "render",
      "type": "render",
      "config": {
        "layers": [
          {
            "source": "board",
            "type": "chessBoard",
            "lightSquares": "#f0d9b5",
            "darkSquares": "#b58863"
          },
          {
            "source": "ChessPiece",
            "type": "piece"
          },
          {
            "source": "cursor",
            "type": "highlight"
          },
          {
            "source": "Selected",
            "type": "highlight",
            "color": "#0f0"
          },
          {
            "source": "state",
            "type": "hud",
            "fields": [
              "currentTurn",
              "moveCount"
            ]
          }
        ]
      }
    }
  ],
  "rules": [
    {
      "when": {
        "event": "pieceCaptured"
      },
      "then": {
        "increment": {
          "state.score": "event.value"
        }
      }
    },
    {
      "when": {
        "event": "moveMade"
      },
      "then": {
        "increment": {
          "state.moveCount": 1
        },
        "set": {
          "state.currentTurn": "event.nextTurn"
        }
      }
    },
    {
      "when": {
        "condition": "state.whiteInCheck && state.currentTurn === 'white'"
      },
      "then": {
        "action": "checkForCheckmate"
      }
    },
    {
      "when": {
        "condition": "state.blackInCheck && state.currentTurn === 'black'"
      },
      "then": {
        "action": "checkForCheckmate"
      }
    },
    {
      "when": {
        "event": "checkmate"
      },
      "then": {
        "set": {
          "state.gameOver": true
        }
      }
    }
  ]
}